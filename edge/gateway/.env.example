# VineGuard Gateway — environment configuration template
# Copy to .env and fill in real values.  NEVER commit .env with real secrets.

# ─── Runtime environment ─────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── LoRa / radio mode ───────────────────────────────────────────────────────
# mock           : synthetic payloads (no hardware, for development / CI)
# serial_json    : read VGPAYLOAD:<json> lines from USB serial
# serial_binary  : read raw VGPP-1 binary frames from USB serial
# chirpstack_mqtt: subscribe to ChirpStack MQTT application topic
LORA_MODE=mock

LORA_SERIAL_PORT=/dev/ttyUSB0
# Must match firmware monitor_speed (default 115200 in new firmware)
LORA_BAUD_RATE=115200

# ─── MQTT broker ────────────────────────────────────────────────────────────
MQTT_HOST=mqtt
MQTT_PORT=8883
MQTT_TOPIC=vineguard/telemetry
MQTT_USERNAME=gateway_publisher
MQTT_PASSWORD=change_me_in_production

# ─── TLS ─────────────────────────────────────────────────────────────────────
CA_CERT_PATH=certs/ca.crt
# Leave empty for server-only TLS (no client certificate)
CLIENT_CERT_PATH=
CLIENT_KEY_PATH=

# ─── Offline cache ───────────────────────────────────────────────────────────
OFFLINE_CACHE_PATH=./data/offline-cache.jsonl

# ─── Health / OTA ────────────────────────────────────────────────────────────
HEALTH_PORT=8080
OTA_CONTROL_URL=https://cloud.vineguard.local/api/ota

# ─── Gateway identity ─────────────────────────────────────────────────────────
GATEWAY_ID=vg-gw-001
